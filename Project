#include <stdint.h>                 // gives fixed-width integer types like uint32_t, int, etc.
#include "tm4c1294ncpdt.h"          // MCU register definitions (Port E/M registers, SYSCTL registers, etc.)
#include "SysTick.h"                
#include "PLL.h"                    

//global variables
int MotorRunning = 0;      // 0 = stopped, 1 = running
int clockWise = 1;         // 1 = CW, 0 = CCW
int Angle11 = 1;           // 1 = 11.25 degree mode, 0 = 45 degree mode

int fullSeqIndex = 0;          // stepper sequence index: 0 to 3
int stepCount = 0;         // counts steps during one run
int currentPosition = 0;   // tracks shaft position from 0 to 31
int homePosition=0;				//saved home position
void PortM_Init(void){
	SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R11;             // turn ON clock for Port M
	while((SYSCTL_PRGPIO_R & SYSCTL_PRGPIO_R11) == 0){};  // wait until Port M is ready

	GPIO_PORTM_DIR_R &= 0b11111100;                        // set PM0-PM1 direction = 0 (INPUT) (PM0-PM3 are used)
  GPIO_PORTM_DEN_R |= 0b00000011;												// digital enable 	
	GPIO_PORTM_PDR_R = 0b00000011;											//Internal Pull down resistor  
	                        
	return;                                               // exit function
}
void PortN_Init(void){
	SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R12;             // turn ON clock for Port N
	while((SYSCTL_PRGPIO_R & SYSCTL_PRGPIO_R12) == 0){};  // wait until Port N is ready

	GPIO_PORTN_DIR_R |= 0b00000011;                        // set PN0-PN1 direction =1 (output) (PM0-PM3 are used)
  GPIO_PORTN_DEN_R |= 0b00000011;												// digital enable 	
	GPIO_PORTN_DATA_R &= ~0b00000011;									// LEDs off initially		
	                        
	return;                                               // exit function
}

void PortF_Init(void){
	SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R5;             // turn ON clock for Port F
	while((SYSCTL_PRGPIO_R & SYSCTL_PRGPIO_R5) == 0){};  // wait until Port F is ready

	GPIO_PORTF_DIR_R |= 0b00011111;                        //
  GPIO_PORTF_DEN_R |= 0b00011111;												// digital enable 	
	GPIO_PORTF_DATA_R &= ~0b00010001;                      // LEDs off initially											
	                        
	return;                                               // exit function
}
void PortJ_Init(void){
	SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R8;
	while((SYSCTL_PRGPIO_R & SYSCTL_PRGPIO_R8) == 0){};

	GPIO_PORTJ_DIR_R &= 0b11111100;     
	GPIO_PORTJ_DEN_R |= 0b00000011;     
	GPIO_PORTJ_PCTL_R &= ~0x000000F0;   
	GPIO_PORTJ_AMSEL_R &= 0b11111100;   
	GPIO_PORTJ_PUR_R |= 0b00000011;     // use pull-up, not pull-down
	return;
}

void PortH_Init(void){
	SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R7;             // turn ON clock for Port M
	while((SYSCTL_PRGPIO_R & SYSCTL_PRGPIO_R7) == 0){};  // wait until Port M is ready

	GPIO_PORTH_DIR_R |= 0b00001111;                        // set PH0-PH7 direction = 0 (INPUT) (PM0-PM3 are used)
  GPIO_PORTH_DEN_R |= 0b00001111;												// digital enable 	
	GPIO_PORTH_DATA_R = 0b00000000;                        // motor off initially											
	                        
	return;                                               // exit function
}

int Button0Pressed(void){ // PJ0, port port j, 1 means not pressed. so 0b00000011 means both buttons not pressed
	return ((GPIO_PORTJ_DATA_R & 0b00000001) == 0); // pull up resistors, so 0 means pressed, 1 means not pressed
}

int Button1Pressed(void){ // PJ1
	return ((GPIO_PORTJ_DATA_R & 0b00000010) == 0); // same as button 0 ,0 means pressed
}
int Button2Pressed(void){ //PM1
	return ((GPIO_PORTM_DATA_R&0b00000010)==0b00000010); //returns 1 if true, 0 if false
}
int Button3Pressed(void){ //PM0
	return ((GPIO_PORTM_DATA_R&0b00000001)==0b00000001); 
}
void MotorOff(void){
	GPIO_PORTH_DATA_R = 0b00000000;
}
// Full-step motor sequence
// this method is used where it doesnt have to loop 512 times. this can be interrupted and does not have to finish
void FullStepMotor(void){
	if(clockWise == 1){
		if(fullSeqIndex == 0) GPIO_PORTH_DATA_R = 0b00000011; //moves the rotor full step angle, 2 coils on
		if(fullSeqIndex == 1) GPIO_PORTH_DATA_R = 0b00000110;
		if(fullSeqIndex == 2) GPIO_PORTH_DATA_R = 0b00001100;
		if(fullSeqIndex == 3) GPIO_PORTH_DATA_R = 0b00001001;

		fullSeqIndex++;
		//each formation is an inex. index 3 is the max. if reached then loops back to index 1.
		if(fullSeqIndex > 3) fullSeqIndex = 0;

		currentPosition++;
		//11.25 degees. so needs 32 steps for 360 reveloution. once reached it loops back to 0. 
		if(currentPosition >= 2048) currentPosition = 0; //after 360 revolution you are back to intial spot
	}
	else{ //counter clockwise
		if(fullSeqIndex == 0) GPIO_PORTH_DATA_R = 0b00001001; // which magnets are on. this is for clockwise formation
		if(fullSeqIndex == 1) GPIO_PORTH_DATA_R = 0b00001100;
		if(fullSeqIndex == 2) GPIO_PORTH_DATA_R = 0b00000110;
		if(fullSeqIndex == 3) GPIO_PORTH_DATA_R = 0b00000011;
		fullSeqIndex++;
		if(fullSeqIndex > 3) fullSeqIndex = 0;

		currentPosition--;
		//counter clockwise so reverse. once reaches 0 then 31
		if(currentPosition < 0) currentPosition = 2047;
	}

	SysTick_Wait10ms(1);
}

void UpdateLEDs(void)
{
	// LED0 on PN1: motor running
	if(MotorRunning == 1)
		GPIO_PORTN_DATA_R |= 0b00000010;
	else
		GPIO_PORTN_DATA_R &= 0b11111101;
	// LED1 on PN0: clockwise
	if(clockWise == 1&&MotorRunning==1)
		GPIO_PORTN_DATA_R |= 0b00000001;
	else
		GPIO_PORTN_DATA_R &= 0b11111110;
	// LED2 on PF4: 11.25 degree mode
	if (Angle11 == 1&&MotorRunning==1)
		GPIO_PORTF_DATA_R |= 0b00010000;
	else
		GPIO_PORTF_DATA_R &= 0b11101111;
}
void BlinkLED3(void){
	GPIO_PORTF_DATA_R |= 0b00000001;   // PF0 on
	SysTick_Wait10ms(1);
	GPIO_PORTF_DATA_R &= 0b11111110;   // PF0 off
}
	
// Home Function
// Return to 0 degrees
// Stop motor
// Clear all LEDs

void GoHome(void){
	MotorRunning = 0;
	stepCount = 0;
	if(clockWise == 1)
		clockWise = 0;
  else
		clockWise = 1;
	UpdateLEDs();
	
	// simple home: keep rotating CCW until currentPosition = 0
	while(currentPosition != homePosition){   //this is where home changes. if home has  to be the same then: while(currentPosition!=0)
		UpdateLEDs();
		FullStepMotor();
		
	}
	Angle11 = 1;
	MotorOff();

	// all LEDs off
	GPIO_PORTN_DATA_R = 0b00000000;
	GPIO_PORTF_DATA_R &= 0b11101110;
}

int main(void){
	PLL_Init();
	SysTick_Init();
	PortF_Init();
	PortH_Init();
	PortM_Init();
	PortJ_Init();
	PortN_Init();
	UpdateLEDs();
	int oldB0 = 0; // old button to check for change
	int oldB1 = 0;
	int oldB2 = 0;
	int oldB3 = 0;

	while(1)
	{
		int newB0 = Button0Pressed(); //get new button inputs
		int newB1 = Button1Pressed();
		int newB2 = Button2Pressed();
		int newB3 = Button3Pressed();
		// Button 0: Start / Stop
		if(newB0 && !oldB0){ // check if the button has been pressed
			if(MotorRunning == 1){ //if was running then now off
				MotorRunning = 0;
				homePosition=currentPosition; // if home doesnt need to change then remove this
			}
			else{
				MotorRunning = 1;// vice versa
				stepCount = 0;
			}
			UpdateLEDs();// update Led settings becuase of changes
			SysTick_Wait10ms(10);   // debounce
		}
		// Button 1: Direction
		if(newB1 && !oldB1){ // check for button press
			if(clockWise == 1) //change direction
				clockWise = 0;
			else
				clockWise = 1;

			UpdateLEDs();
			SysTick_Wait10ms(10);
		}
		// Button 2: Angle toggle
		if(newB2 && !oldB2){ //check for button press
			if(Angle11 == 1)
				Angle11 = 0;
			else
				Angle11 = 1;

			UpdateLEDs();
			SysTick_Wait10ms(10);
		}

		// --------------------------------
		// Button 3: Home
		// --------------------------------
		if(newB3 && !oldB3){ //check button press 
			GoHome();
			SysTick_Wait10ms(10);
		}

		oldB0 = newB0; //after all checks now make old status equal the new status
		oldB1 = newB1;
		oldB2 = newB2;
		oldB3 = newB3;

		// --------------------------------
		// Run motor if enabled
		// --------------------------------
		if(MotorRunning == 1){
			FullStepMotor();
			stepCount++;
			// use the selected stepping function
			if(Angle11 == 1){
				if ((stepCount%64)==0){
					
					BlinkLED3();                 // blink every 11.25 degree step
				}
			}
			else{
				
				if((stepCount % 256) == 0){   // blink every 45 degree interval 360*(256/2048)
					BlinkLED3();
				}
			}

			UpdateLEDs();

			// auto stop after one full rotation
			if(stepCount >= 2048){
				MotorRunning = 0;
				stepCount = 0;
				homePosition=currentPosition; //save current stop position as new home. Remove if not needed 
				MotorOff();
				UpdateLEDs();
			}
		}
		else{
			MotorOff();
		}
	}
}
		
