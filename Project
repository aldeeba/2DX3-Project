#include <stdint.h>                 // gives fixed-width integer types like uint32_t, int, etc.
#include "tm4c1294ncpdt.h"          // MCU register definitions (Port E/M registers, SYSCTL registers, etc.)
#include "SysTick.h"                // (not used in this file) systick helper functions
#include "PLL.h"                    // (not used in this file) PLL helper functions

void PortM_Init(void){
	SYSCTL_RCGCGPIO_R |= SYSCTL_RCGCGPIO_R11;             // turn ON clock for Port M
	while((SYSCTL_PRGPIO_R & SYSCTL_PRGPIO_R11) == 0){};  // wait until Port M is ready

	GPIO_PORTM_DIR_R &= 0b11111100;                        // set PM0-PM1 direction = 0 (INPUT) (PM0-PM3 are used)
  GPIO_PORTM_DEN_R |= 0b00000011;												// digital enable 	
												
	                        
	return;                                               // exit function
}
